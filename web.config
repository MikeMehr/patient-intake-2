<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <security>
      <requestFiltering>
        <!-- Allow up to ~200 MB uploads (value in bytes) -->
        <requestLimits maxAllowedContentLength="209715200" />
      </requestFiltering>
    </security>
  </system.webServer>
  <system.web>
    <!-- ASP.NET max request size in KB (~200 MB) -->
    <httpRuntime maxRequestLength="204800" />
  </system.web>
</configuration>
